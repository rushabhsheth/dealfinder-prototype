# DealFinder frontend env. Copy to app/.env (git-ignored).

# Base URL of the backend (server/). Set this to flip the app from pure-demo/mock
# mode into LIVE mode (real auth + Gmail connect via the API).
# Leave it UNSET to keep the prototype-style demo with mock data.
VITE_API_BASE=http://localhost:8787

# Supabase browser client — used for AUTH ONLY (Continue with Google + email/
# password). The anon key is safe in the browser (RLS protects data). Inbox
# access never happens client-side. Both required for "Continue with Google".
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your anon public key>
