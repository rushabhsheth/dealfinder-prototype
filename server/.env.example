# DealFinder server — environment template.
# Copy to server/.env (git-ignored) and fill in. NEVER commit real values.
# Generate the token-encryption key with:  npm run gen:key

# ── Runtime ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8787
# Comma-separated origins allowed to call the API (the app/ frontend in dev).
CORS_ORIGIN=http://localhost:5173

# ── Supabase (managed Postgres + Auth) ───────────────────────────────────
# Project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=
# Anon (public) key — safe in the browser, used to verify user JWTs server-side.
SUPABASE_ANON_KEY=
# Service-role key — FULL ACCESS, server-only. Bypasses RLS. Never ship to client.
SUPABASE_SERVICE_ROLE_KEY=

# ── OAuth-token encryption ───────────────────────────────────────────────
# 32 random bytes, base64-encoded (AES-256-GCM key) used to encrypt Google
# OAuth tokens at rest before they're written to oauth_connections.token_ciphertext.
# This key lives ONLY here / in the host secret store — never in the database,
# never in the repo. Rotating it requires re-encrypting stored tokens.
TOKEN_ENCRYPTION_KEY=

# ── Google OAuth (Phase 1 — not used yet, listed so the shape is known) ──
# Only the gmail.readonly scope will ever be requested. No write/send/modify.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8787/auth/google/callback

# ── Anthropic (Phase 2 — server-side structured extraction) ──────────────
ANTHROPIC_API_KEY=
