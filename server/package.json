{
  "name": "dealfinder-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "DealFinder real webapp backend — Fastify + TypeScript + Supabase. Owns OAuth tokens, entitlements, brands/offers/savings, and the (later) Gmail scan pipeline.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "gen:key": "node --input-type=module -e \"import('node:crypto').then(c=>console.log(c.randomBytes(32).toString('base64')))\""
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/sensible": "^6.0.2",
    "@supabase/supabase-js": "^2.45.4",
    "fastify": "^5.1.0",
    "ws": "^8.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
